-    message: validation.overall === 'FAIL'
-      ? `❌ RM FAIL — CAPA ${capa_id} auto-created`
-      : validation.overall === 'HOLD'
-        ? `⏸️ RM ON HOLD — QA disposition required`
-        : `✅ RM PASS — Released to storage`
