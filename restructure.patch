+++ b/src/worker.js
@@ -0,0 +1,117 @@
+const json = (data, status = 200) => new Response(JSON.stringify(data, null, 2), {
+  status,
+  headers: { "content-type": "application/json; charset=utf-8" }
+});
+
+const fail = (message, status = 400, details = null) => json({ ok: false, message, details }, status);
+const ok = (data = {}) => json({ ok: true, ...data });
+
+const allowedColumns = {
+  users: ["user_id","full_name","email","department","role","status"],
+  suppliers: ["supplier_id","supplier_name","material_type","risk_level","coa_required","halal_cert","gmp_status","approved_status","last_audit_date","material_code"],
+  materials: ["material_code","material_name","material_type","category","unit","min_temp_c","max_temp_c","storage_temp","shelf_life_days","risk_level","supplier_id"],
+  finished_goods: ["fg_code","fg_name","product_type","storage_temp_c","shelf_life_days","min_weight_g","max_weight_g","min_weight_pack_g","max_weight_pack_g"],
+  processes: ["process_id","process_name","description","work_area","sequence_no"],
+  parameters: ["parameter_id","parameter_name","parameter_description","parameter_category","spec_limit","unit"],
+  equipment: ["equipment_id","equipment_name","equipment_type","location","calibration_required","status"],
+  ccp_master: ["ccp_id","process_id","ccp_name","critical_limit"],
+  process_parameter_map: ["map_id","process_id","parameter_id","equipment_id","frequency","is_ccp"],
+  documents: ["document_id","document_no","category","document_name","revision","effective_date","system","owner","location","status","storage_key"],
+  document_versions: ["version_id","document_id","revision","file_key","approved_by","approved_at","effective_date","status"],
+  inspection_logs: ["inspection_id","inspection_date","shift","line","product_code","lot_no","process_id","parameter_id","spec_limit","value_text","value_num","unit","result","severity","inspector_id","remark"],
+  ccp_monitoring_logs: ["ccp_log_id","inspection_date","line","ccp_id","product_code","lot_no","critical_limit","value_text","value_num","unit","result","action_taken","verified_by"],
+  metal_detector_logs: ["metal_log_id","inspection_date","line","product_code","lot_no","fe_mm","non_fe_mm","sus_mm","reject_ok","result","action_taken","inspector_id","verified_by"],
+  ghp_logs: ["ghp_log_id","log_date","program","area","item_checked","standard","result","action_taken","inspector_id"],
+  receiving_lots: ["receiving_id","receiving_date","supplier_id","material_code","lot_no","qty","unit","temp_c","coa_status","visual_result","packaging_result","result","lot_status","inspector_id"],
+  ncr_records: ["ncr_id","source_module","source_record_id","issue_date","product_code","lot_no","issue_description","severity","status","disposition","qa_decision","created_by","closed_at"],
+  capa_records: ["capa_id","ncr_id","root_cause","correction","corrective_action","owner","due_date","status","effectiveness_check","closed_at"],
+  customer_complaints: ["complaint_id","complaint_date","customer","product_code","lot_no","issue","severity","recall_risk","status","capa_id"],
+  lot_chain: ["trace_id","batch_id","rm_lot_no","fg_lot_no","product_code","qty_input","qty_output","unit","production_date","line"],
+  attachments: ["attachment_id","module","record_id","file_key","file_name","content_type","uploaded_by"],
+  alerts: ["alert_id","module","record_id","severity","message","status","closed_at"]
+};
+
+const tables = new Set(Object.keys(allowedColumns));
+
+function assertTable(table) {
+  if (!tables.has(table)) throw new Error(`Table not allowed: ${table}`);
+}
+
+async function readJson(request) {
+  try { return await request.json(); } catch { return null; }
+}
+
+async function listRows(env, table, url) {
+  assertTable(table);
+  const limit = Math.min(Number(url.searchParams.get("limit") || 100), 500);
+  const offset = Math.max(Number(url.searchParams.get("offset") || 0), 0);
+  const result = await env.DB.prepare(`SELECT * FROM ${table} LIMIT ? OFFSET ?`).bind(limit, offset).all();
+  return ok({ table, count: result.results.length, rows: result.results });
+}
+
+async function insertRow(env, table, payload) {
+  assertTable(table);
+  if (!payload || typeof payload !== "object") return fail("Invalid JSON payload");
+  const cols = allowedColumns[table].filter(c => Object.prototype.hasOwnProperty.call(payload, c));
+  if (cols.length === 0) return fail("No allowed columns found in payload");
+  const placeholders = cols.map(() => "?").join(",");
+  const sql = `INSERT INTO ${table} (${cols.join(",")}) VALUES (${placeholders})`;
+  await env.DB.prepare(sql).bind(...cols.map(c => payload[c])).run();
+  return ok({ table, inserted: true });
+}
+
+async function dashboard(env) {
+  const row = await env.DB.prepare("SELECT * FROM v_dashboard_kpi").first();
+  const total = row?.total_inspections ?? 0;
+  const passCount = row?.pass_count ?? 0;
+  const failCount = row?.fail_count ?? 0;
+  const ccpFail = row?.ccp_fail_count ?? 0;
+  const mdFail = (await env.DB.prepare("SELECT COUNT(*) AS total FROM metal_detector_logs WHERE result='FAIL'").first())?.total ?? 0;
+  const activeDocs = (await env.DB.prepare("SELECT COUNT(*) AS total FROM documents WHERE status='ACTIVE'").first())?.total ?? 0;
+  const passRate = total ? Math.round((passCount / total) * 10000) / 100 : 0;
+  return ok({
+    kpi: {
+      total_checks: total,
+      pass: passCount,
+      fail: failCount,
+      pass_rate_percent: passRate,
+      ccp_fail: ccpFail,
+      metal_detector_fail: mdFail,
+      open_ncr: row?.open_ncr ?? 0,
+      open_capa: row?.open_capa ?? 0,
+      open_complaints: row?.open_complaints ?? 0,
+      active_documents: activeDocs,
+      qa_status: (failCount || ccpFail || mdFail) ? "ATTENTION REQUIRED" : "UNDER CONTROL"
+    }
+  });
+}
+
+async function uploadDocument(env, request) {
+  const form = await request.formData();
+  const file = form.get("file");
+  const docCode = form.get("document_no") || form.get("doc_code");
+  if (!file || !docCode) return fail("file and document_no are required");
+  const key = `documents/${docCode}/${Date.now()}-${file.name}`;
+  await env.DOC_BUCKET.put(key, file.stream(), { httpMetadata: { contentType: file.type } });
+  return ok({ storage_key: key });
+}
+
+export default {
+  async fetch(request, env) {
+    const url = new URL(request.url);
+    if (url.pathname.startsWith("/api/")) {
+      try {
+        if (url.pathname === "/api/health") return ok({ service: "Smart QA Factory", version: "1.0 MASTER BASELINE" });
+        if (url.pathname === "/api/dashboard") return dashboard(env);
+        if (url.pathname === "/api/documents/upload" && request.method === "POST") return uploadDocument(env, request);
+        const match = url.pathname.match(/^\/api\/table\/([a-z_]+)$/);
+        if (match && request.method === "GET") return listRows(env, match[1], url);
+        if (match && request.method === "POST") return insertRow(env, match[1], await readJson(request));
+        return fail("API route not found", 404);
+      } catch (err) {
+        return fail(err.message, 500);
+      }
+    }
+    return env.ASSETS.fetch(request);
+  }
+};
