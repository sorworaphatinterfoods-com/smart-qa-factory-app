-/* ── Mobile ── */
-@media(max-width:1024px){.grid-2,.grid-3{grid-template-columns:1fr}.kpi-grid{grid-template-columns:repeat(auto-fit,minmax(140px,1fr))}.form-grid{grid-template-columns:1fr}}
